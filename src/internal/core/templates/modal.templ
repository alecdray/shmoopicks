package templates

const globalModalContainerId = "global-modal-container"

templ ModalContainer(isSwap bool) {
	<div
		id={ globalModalContainerId }
		if isSwap {
			hx-swap-oob="true"
		}
	>
		{ children... }
	</div>
}

type ModalProps struct {
	ModalContent templ.Component
	ModalActions templ.Component
}

templ Modal(id string, props ModalProps) {
	@ModalContainer(true) {
		<dialog id={ id } class="modal" open>
			<div class="modal-box">
				<form method="dialog">
					<button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
				</form>
				if props.ModalContent != nil {
					@props.ModalContent
				}
				if props.ModalActions != nil {
					<div class="modal-action">
						<form method="dialog">
							@props.ModalActions
						</form>
					</div>
				}
			</div>
		</dialog>
	}
}
